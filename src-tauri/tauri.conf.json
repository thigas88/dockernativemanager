{
  "productName": "Docker Native Manager",
  "version": "1.12.0",
  "identifier": "com.pflabs.dockernm",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:8080",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Docker Native Manager",
        "width": 1280,
        "height": 720,
        "decorations": false,
        "transparent": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "depends": []
      }
    }
  }
}
